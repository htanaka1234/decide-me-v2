{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/session-state.schema.json",
  "title": "Decide Me Session State",
  "type": "object",
  "required": [
    "schema_version",
    "session",
    "summary",
    "classification",
    "close_summary",
    "working_state"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 11
    },
    "session": {
      "type": "object",
      "required": [
        "id",
        "started_at",
        "last_seen_at",
        "bound_context_hint",
        "related_object_ids",
        "lifecycle"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "started_at": {
          "type": "string"
        },
        "last_seen_at": {
          "type": "string"
        },
        "bound_context_hint": {
          "type": [
            "string",
            "null"
          ]
        },
        "related_object_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lifecycle": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object"
    },
    "classification": {
      "type": "object",
      "required": [
        "domain",
        "abstraction_level",
        "assigned_tags",
        "search_terms",
        "source_refs",
        "updated_at"
      ],
      "properties": {
        "domain": {
          "type": [
            "string",
            "null"
          ]
        },
        "abstraction_level": {
          "type": [
            "string",
            "null"
          ]
        },
        "domain_pack_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "domain_pack_version": {
          "type": "string",
          "minLength": 1
        },
        "domain_pack_digest": {
          "type": "string",
          "pattern": "^DP-[0-9a-f]{12}$"
        },
        "assigned_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "search_terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updated_at": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "close_summary": {
      "$ref": "./close-summary.schema.json"
    },
    "working_state": {
      "type": "object",
      "required": [
        "active_question_id",
        "active_proposal_id",
        "last_seen_project_head"
      ],
      "properties": {
        "active_question_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "active_proposal_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_seen_project_head": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
