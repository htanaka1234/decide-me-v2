{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/session-state.schema.json",
  "title": "Decide Me Session State",
  "type": "object",
  "required": [
    "schema_version",
    "session",
    "summary",
    "classification",
    "close_summary",
    "working_state"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 9
    },
    "session": {
      "type": "object",
      "required": [
        "id",
        "started_at",
        "last_seen_at",
        "bound_context_hint",
        "decision_ids",
        "lifecycle"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "started_at": {
          "type": "string"
        },
        "last_seen_at": {
          "type": "string"
        },
        "bound_context_hint": {
          "type": [
            "string",
            "null"
          ]
        },
        "decision_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lifecycle": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object"
    },
    "classification": {
      "type": "object",
      "required": [
        "domain",
        "abstraction_level",
        "assigned_tags",
        "search_terms",
        "source_refs",
        "updated_at"
      ],
      "properties": {
        "domain": {
          "type": [
            "string",
            "null"
          ]
        },
        "abstraction_level": {
          "type": [
            "string",
            "null"
          ]
        },
        "assigned_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "search_terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updated_at": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "close_summary": {
      "$ref": "./close-summary.schema.json"
    },
    "working_state": {
      "type": "object",
      "required": [
        "current_question_id",
        "current_question",
        "active_proposal",
        "last_seen_project_head"
      ],
      "properties": {
        "current_question_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "current_question": {
          "type": [
            "string",
            "null"
          ]
        },
        "active_proposal": {
          "type": "object",
          "required": [
            "proposal_id",
            "origin_session_id",
            "target_type",
            "target_id",
            "recommendation_version",
            "based_on_project_head",
            "is_active",
            "activated_at",
            "inactive_reason",
            "question_id",
            "question",
            "recommendation",
            "why",
            "if_not"
          ],
          "properties": {
            "proposal_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "origin_session_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "target_type": {
              "type": [
                "string",
                "null"
              ]
            },
            "target_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "recommendation_version": {
              "type": [
                "integer",
                "null"
              ]
            },
            "based_on_project_head": {
              "type": [
                "string",
                "null"
              ]
            },
            "is_active": {
              "type": "boolean"
            },
            "activated_at": {
              "type": [
                "string",
                "null"
              ]
            },
            "inactive_reason": {
              "type": [
                "string",
                "null"
              ]
            },
            "question_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "question": {
              "type": [
                "string",
                "null"
              ]
            },
            "recommendation": {
              "type": [
                "string",
                "null"
              ]
            },
            "why": {
              "type": [
                "string",
                "null"
              ]
            },
            "if_not": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": true
        },
        "last_seen_project_head": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
