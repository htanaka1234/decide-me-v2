{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/project-state.schema.json",
  "title": "Decide Me Project State",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "state",
      "protocol",
      "counts",
      "default_bundles",
      "session_graph",
      "decisions"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 8
    },
    "project": {
      "type": "object",
      "required": [
        "name",
        "objective",
        "current_milestone",
        "stop_rule"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "current_milestone": {
          "type": "string",
          "minLength": 1
        },
        "stop_rule": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "state": {
      "type": "object",
      "required": [
        "project_head",
        "event_count",
        "updated_at",
        "last_event_id"
      ],
      "properties": {
        "project_head": {
          "type": "string",
          "minLength": 1
        },
        "event_count": {
          "type": "integer",
          "minimum": 1
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_event_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "protocol": {
      "type": "object"
    },
    "counts": {
      "type": "object"
    },
    "default_bundles": {
      "type": "array"
    },
    "session_graph": {
      "type": "object",
      "required": [
        "nodes",
        "edges",
        "inferred_candidates",
        "resolved_conflicts"
      ],
      "properties": {
        "nodes": {
          "type": "array"
        },
        "edges": {
          "type": "array"
        },
        "inferred_candidates": {
          "type": "array"
        },
        "resolved_conflicts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "conflict_id",
              "winning_session_id",
              "rejected_session_ids",
              "scope",
              "suppressed_context",
              "reason",
              "resolved_at",
              "event_id"
            ],
            "properties": {
              "suppressed_context": {
                "type": "object",
                "required": [
                  "session_ids",
                  "decision_ids",
                  "action_slice_names",
                  "workstream_names",
                  "hidden_strings"
                ],
                "properties": {
                  "session_ids": {
                    "type": "array"
                  },
                  "decision_ids": {
                    "type": "array"
                  },
                  "action_slice_names": {
                    "type": "array"
                  },
                  "workstream_names": {
                    "type": "array"
                  },
                  "hidden_strings": {
                    "type": "array"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "requirement_id",
          "title",
          "kind",
          "domain",
          "priority",
          "frontier",
          "status",
          "resolvable_by",
          "reversibility",
          "depends_on",
          "blocked_by",
          "question",
          "context",
          "options",
          "recommendation",
          "accepted_answer",
          "resolved_by_evidence",
          "evidence_refs",
          "revisit_triggers",
          "notes",
          "bundle_id",
          "invalidated_by"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "requirement_id": {
            "type": "string",
            "pattern": "^R-[0-9]{3,}$"
          },
          "title": {
            "type": [
              "string",
              "null"
            ]
          },
          "kind": {
            "type": "string",
            "enum": [
              "choice",
              "constraint",
              "risk",
              "dependency"
            ]
          },
          "domain": {
            "type": "string",
            "enum": [
              "product",
              "technical",
              "data",
              "ux",
              "ops",
              "legal",
              "other"
            ]
          },
          "priority": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2"
            ]
          },
          "frontier": {
            "type": "string",
            "enum": [
              "now",
              "later",
              "discovered-later",
              "deferred"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "unresolved",
              "proposed",
              "rejected",
              "blocked",
              "accepted",
              "deferred",
              "resolved-by-evidence",
              "invalidated"
            ]
          },
          "resolvable_by": {
            "type": "string",
            "enum": [
              "human",
              "codebase",
              "docs",
              "tests",
              "external"
            ]
          },
          "reversibility": {
            "type": "string",
            "enum": [
              "reversible",
              "hard-to-reverse",
              "irreversible",
              "unknown"
            ]
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocked_by": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "question": {
            "type": [
              "string",
              "null"
            ]
          },
          "context": {
            "type": [
              "string",
              "null"
            ]
          },
          "options": {
            "type": "array"
          },
          "recommendation": {
            "type": "object",
            "required": [
              "proposal_id",
              "version",
              "summary",
              "rationale_short",
              "confidence",
              "proposed_at",
              "based_on_project_head"
            ],
            "properties": {
              "proposal_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "version": {
                "type": "integer"
              },
              "summary": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "rationale_short": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "confidence": {
                "type": "string"
              },
              "proposed_at": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "based_on_project_head": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          },
          "accepted_answer": {
            "type": "object",
            "required": [
              "summary",
              "accepted_at",
              "accepted_via",
              "proposal_id"
            ],
            "properties": {
              "summary": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "accepted_at": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "accepted_via": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  "ok",
                  "explicit",
                  "evidence",
                  null
                ]
              },
              "proposal_id": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          },
          "resolved_by_evidence": {
            "type": "object",
            "required": [
              "source",
              "summary",
              "resolved_at",
              "evidence_refs"
            ],
            "properties": {
              "source": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  "codebase",
                  "docs",
                  "tests",
                  "external",
                  "existing-decisions",
                  "close-summaries",
                  null
                ]
              },
              "summary": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "resolved_at": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "revisit_triggers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "bundle_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "agent_relevant": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "invalidated_by": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "decision_id",
              "reason",
              "invalidated_at"
            ],
            "properties": {
              "decision_id": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "invalidated_at": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true,
        "allOf": [
          {
            "if": {
              "properties": {
                "status": {
                  "const": "accepted"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "properties": {
                "accepted_answer": {
                  "properties": {
                    "summary": {
                      "type": "string",
                      "minLength": 1
                    },
                    "accepted_at": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "accepted_via": {
                      "type": "string",
                      "enum": [
                        "ok",
                        "explicit"
                      ]
                    },
                    "proposal_id": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "status": {
                  "const": "resolved-by-evidence"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "properties": {
                "accepted_answer": {
                  "properties": {
                    "summary": {
                      "type": "string",
                      "minLength": 1
                    },
                    "accepted_via": {
                      "const": "evidence"
                    }
                  }
                },
                "resolved_by_evidence": {
                  "properties": {
                    "source": {
                      "type": "string",
                      "enum": [
                        "codebase",
                        "docs",
                        "tests",
                        "external",
                        "existing-decisions",
                        "close-summaries"
                      ]
                    },
                    "summary": {
                      "type": "string",
                      "minLength": 1
                    },
                    "resolved_at": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "status": {
                  "enum": [
                    "unresolved",
                    "proposed",
                    "rejected",
                    "deferred",
                    "blocked"
                  ]
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "properties": {
                "accepted_answer": {
                  "properties": {
                    "summary": {
                      "type": "null"
                    }
                  }
                },
                "resolved_by_evidence": {
                  "properties": {
                    "summary": {
                      "type": "null"
                    }
                  }
                }
              }
            }
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
