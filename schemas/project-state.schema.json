{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/project-state.schema.json",
  "title": "Decide Me Project State",
  "$comment": "Phase 5 runtime projection schema. Runtime project-state is the v10 protocol/session-index/object/link/graph state.",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "state",
    "protocol",
    "sessions_index",
    "counts",
    "objects",
    "links",
    "graph"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 10
    },
    "project": {
      "type": "object",
      "required": [
        "name",
        "objective",
        "current_milestone",
        "stop_rule"
      ],
      "properties": {
        "name": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "objective": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "current_milestone": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "stop_rule": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "state": {
      "type": "object",
      "required": [
        "project_head",
        "event_count",
        "updated_at",
        "last_event_id"
      ],
      "properties": {
        "project_head": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "event_count": {
          "type": "integer",
          "minimum": 0
        },
        "updated_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "last_event_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "protocol": {
      "type": "object",
      "required": [
        "plain_ok_scope",
        "proposal_expiry_rules",
        "close_policy"
      ],
      "properties": {
        "plain_ok_scope": {
          "type": "string",
          "minLength": 1
        },
        "proposal_expiry_rules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "close_policy": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "sessions_index": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/session_index_entry"
      }
    },
    "counts": {
      "type": "object",
      "required": [
        "object_total",
        "link_total",
        "by_type",
        "by_status",
        "by_relation"
      ],
      "properties": {
        "object_total": {
          "type": "integer",
          "minimum": 0
        },
        "link_total": {
          "type": "integer",
          "minimum": 0
        },
        "by_type": {
          "$ref": "#/$defs/object_type_counts"
        },
        "by_status": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "by_relation": {
          "$ref": "#/$defs/relation_counts"
        }
      },
      "additionalProperties": false
    },
    "objects": {
      "type": "array",
      "items": {
        "$ref": "object.schema.json"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "link.schema.json"
      }
    },
    "graph": {
      "type": "object",
      "required": [
        "nodes",
        "edges",
        "resolved_conflicts",
        "inferred_candidates"
      ],
      "properties": {
        "nodes": {
          "type": "array"
        },
        "edges": {
          "type": "array"
        },
        "resolved_conflicts": {
          "type": "array"
        },
        "inferred_candidates": {
          "type": "array"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "required": [
          "state"
        ],
        "properties": {
          "state": {
            "required": [
              "event_count"
            ],
            "properties": {
              "event_count": {
                "const": 0
              }
            }
          }
        }
      },
      "then": {},
      "else": {
        "properties": {
          "project": {
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "objective": {
                "type": "string",
                "minLength": 1
              },
              "current_milestone": {
                "type": "string",
                "minLength": 1
              },
              "stop_rule": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "state": {
            "properties": {
              "project_head": {
                "type": "string",
                "minLength": 1
              },
              "updated_at": {
                "type": "string",
                "format": "date-time"
              },
              "last_event_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "object_type": {
      "type": "string",
      "enum": [
        "objective",
        "constraint",
        "criterion",
        "option",
        "proposal",
        "decision",
        "assumption",
        "evidence",
        "risk",
        "action",
        "verification",
        "revisit_trigger",
        "artifact"
      ]
    },
    "link_relation": {
      "type": "string",
      "enum": [
        "depends_on",
        "supports",
        "challenges",
        "recommends",
        "accepts",
        "addresses",
        "verifies",
        "revisits",
        "supersedes",
        "blocked_by"
      ]
    },
    "session_index_entry": {
      "type": "object",
      "required": [
        "id",
        "status",
        "started_at",
        "last_seen_at",
        "closed_at",
        "bound_context_hint",
        "decision_ids"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_seen_at": {
          "type": "string",
          "format": "date-time"
        },
        "closed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "bound_context_hint": {
          "type": [
            "string",
            "null"
          ]
        },
        "decision_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "object_type_counts": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/object_type"
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "relation_counts": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/link_relation"
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
