{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/project-state.schema.json",
  "title": "Decide Me Project State",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "state",
    "counts",
    "objects",
    "links"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 10
    },
    "project": {
      "type": "object",
      "required": [
        "name",
        "objective",
        "current_milestone",
        "stop_rule"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "current_milestone": {
          "type": "string",
          "minLength": 1
        },
        "stop_rule": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "state": {
      "type": "object",
      "required": [
        "project_head",
        "event_count",
        "updated_at",
        "last_event_id"
      ],
      "properties": {
        "project_head": {
          "type": "string",
          "minLength": 1
        },
        "event_count": {
          "type": "integer",
          "minimum": 1
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_event_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "counts": {
      "type": "object",
      "required": [
        "object_total",
        "link_total",
        "by_type",
        "by_status",
        "by_relation"
      ],
      "properties": {
        "object_total": {
          "type": "integer",
          "minimum": 0
        },
        "link_total": {
          "type": "integer",
          "minimum": 0
        },
        "by_type": {
          "$ref": "#/$defs/object_type_counts"
        },
        "by_status": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "by_relation": {
          "$ref": "#/$defs/relation_counts"
        }
      },
      "additionalProperties": false
    },
    "objects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/domain_object"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "object_type": {
      "type": "string",
      "enum": [
        "objective",
        "constraint",
        "criterion",
        "option",
        "proposal",
        "decision",
        "assumption",
        "evidence",
        "risk",
        "action",
        "verification",
        "revisit_trigger",
        "artifact"
      ]
    },
    "link_relation": {
      "type": "string",
      "enum": [
        "depends_on",
        "supports",
        "challenges",
        "recommends",
        "accepts",
        "addresses",
        "verifies",
        "revisits",
        "supersedes",
        "blocked_by"
      ]
    },
    "source_event_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "domain_object": {
      "type": "object",
      "required": [
        "id",
        "type",
        "title",
        "body",
        "status",
        "created_at",
        "updated_at",
        "source_event_ids",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "$ref": "#/$defs/object_type"
        },
        "title": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "body": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "source_event_ids": {
          "$ref": "#/$defs/source_event_ids"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "link": {
      "type": "object",
      "required": [
        "id",
        "source_object_id",
        "relation",
        "target_object_id",
        "rationale",
        "created_at",
        "source_event_ids"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source_object_id": {
          "type": "string",
          "minLength": 1
        },
        "relation": {
          "$ref": "#/$defs/link_relation"
        },
        "target_object_id": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": [
            "string",
            "null"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_event_ids": {
          "$ref": "#/$defs/source_event_ids"
        }
      },
      "additionalProperties": false
    },
    "object_type_counts": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/object_type"
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "relation_counts": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/link_relation"
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
