{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/evaluation-report.schema.json",
  "title": "Decide Me Evaluation Report",
  "type": "object",
  "required": [
    "schema_version",
    "scenario_id",
    "status",
    "generated_at",
    "metrics",
    "failures"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 2
    },
    "scenario_id": {
      "$ref": "#/$defs/identifier"
    },
    "status": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    },
    "failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failure"
      }
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "const": "passed"
          }
        }
      },
      "then": {
        "properties": {
          "failures": {
            "maxItems": 0
          },
          "metrics": {
            "$ref": "#/$defs/all_metrics_passed"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "const": "failed"
          }
        }
      },
      "then": {
        "properties": {
          "failures": {
            "minItems": 1
          },
          "metrics": {
            "$ref": "#/$defs/any_metric_failed"
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "nullable_number": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "metric_name": {
      "enum": [
        "decision_coverage",
        "question_efficiency",
        "conflict_detection_recall",
        "conflict_precision",
        "evidence_linkage_rate",
        "assumption_exposure",
        "risk_coverage",
        "action_executability",
        "document_validity",
        "runtime_performance"
      ]
    },
    "metric_passed_true": {
      "type": "object",
      "required": [
        "passed"
      ],
      "properties": {
        "passed": {
          "const": true
        }
      }
    },
    "metric_passed_false": {
      "type": "object",
      "required": [
        "passed"
      ],
      "properties": {
        "passed": {
          "const": false
        }
      }
    },
    "all_metrics_passed": {
      "type": "object",
      "properties": {
        "decision_coverage": {
          "$ref": "#/$defs/metric_passed_true"
        },
        "question_efficiency": {
          "$ref": "#/$defs/metric_passed_true"
        },
        "conflict_detection_recall": {
          "$ref": "#/$defs/metric_passed_true"
        },
        "conflict_precision": {
          "$ref": "#/$defs/metric_passed_true"
        },
        "evidence_linkage_rate": {
          "$ref": "#/$defs/metric_passed_true"
        },
        "assumption_exposure": {
          "$ref": "#/$defs/metric_passed_true"
        },
        "risk_coverage": {
          "$ref": "#/$defs/metric_passed_true"
        },
        "action_executability": {
          "$ref": "#/$defs/metric_passed_true"
        },
        "document_validity": {
          "$ref": "#/$defs/metric_passed_true"
        },
        "runtime_performance": {
          "$ref": "#/$defs/metric_passed_true"
        }
      }
    },
    "any_metric_failed": {
      "anyOf": [
        {
          "properties": {
            "decision_coverage": {
              "$ref": "#/$defs/metric_passed_false"
            }
          }
        },
        {
          "properties": {
            "question_efficiency": {
              "$ref": "#/$defs/metric_passed_false"
            }
          }
        },
        {
          "properties": {
            "conflict_detection_recall": {
              "$ref": "#/$defs/metric_passed_false"
            }
          }
        },
        {
          "properties": {
            "conflict_precision": {
              "$ref": "#/$defs/metric_passed_false"
            }
          }
        },
        {
          "properties": {
            "evidence_linkage_rate": {
              "$ref": "#/$defs/metric_passed_false"
            }
          }
        },
        {
          "properties": {
            "assumption_exposure": {
              "$ref": "#/$defs/metric_passed_false"
            }
          }
        },
        {
          "properties": {
            "risk_coverage": {
              "$ref": "#/$defs/metric_passed_false"
            }
          }
        },
        {
          "properties": {
            "action_executability": {
              "$ref": "#/$defs/metric_passed_false"
            }
          }
        },
        {
          "properties": {
            "document_validity": {
              "$ref": "#/$defs/metric_passed_false"
            }
          }
        },
        {
          "properties": {
            "runtime_performance": {
              "$ref": "#/$defs/metric_passed_false"
            }
          }
        }
      ]
    },
    "metrics": {
      "type": "object",
      "required": [
        "decision_coverage",
        "question_efficiency",
        "conflict_detection_recall",
        "conflict_precision",
        "evidence_linkage_rate",
        "assumption_exposure",
        "risk_coverage",
        "action_executability",
        "document_validity",
        "runtime_performance"
      ],
      "properties": {
        "decision_coverage": {
          "$ref": "#/$defs/coverage_metric"
        },
        "question_efficiency": {
          "$ref": "#/$defs/question_efficiency_metric"
        },
        "conflict_detection_recall": {
          "$ref": "#/$defs/conflict_recall_metric"
        },
        "conflict_precision": {
          "$ref": "#/$defs/conflict_precision_metric"
        },
        "evidence_linkage_rate": {
          "$ref": "#/$defs/evidence_linkage_metric"
        },
        "assumption_exposure": {
          "$ref": "#/$defs/assumption_exposure_metric"
        },
        "risk_coverage": {
          "$ref": "#/$defs/coverage_metric"
        },
        "action_executability": {
          "$ref": "#/$defs/action_executability_metric"
        },
        "document_validity": {
          "$ref": "#/$defs/document_validity_metric"
        },
        "runtime_performance": {
          "$ref": "#/$defs/runtime_performance_metric"
        }
      },
      "additionalProperties": false
    },
    "question_efficiency_metric": {
      "type": "object",
      "required": [
        "asked_count",
        "max_allowed",
        "passed"
      ],
      "properties": {
        "asked_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "max_allowed": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "repeated_forbidden_decision_types": {
          "$ref": "#/$defs/string_array"
        },
        "passed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "coverage_metric": {
      "type": "object",
      "required": [
        "required_count",
        "covered_count",
        "passed"
      ],
      "properties": {
        "required_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "covered_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "missing_ids": {
          "$ref": "#/$defs/string_array"
        },
        "passed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "conflict_recall_metric": {
      "type": "object",
      "required": [
        "expected_count",
        "actual_count",
        "passed"
      ],
      "properties": {
        "expected_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "actual_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "missing_conflict_ids": {
          "$ref": "#/$defs/string_array"
        },
        "missing_conflict_types": {
          "$ref": "#/$defs/string_array"
        },
        "passed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "conflict_precision_metric": {
      "type": "object",
      "required": [
        "expected_count",
        "actual_count",
        "unexpected_conflict_ids",
        "false_positive_count",
        "passed"
      ],
      "properties": {
        "expected_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "actual_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "unexpected_conflict_ids": {
          "$ref": "#/$defs/string_array"
        },
        "false_positive_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "passed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "evidence_linkage_metric": {
      "type": "object",
      "required": [
        "required_count",
        "covered_count",
        "linked_evidence_count",
        "total_evidence_count",
        "linkage_rate",
        "invalid_source_refs",
        "passed"
      ],
      "properties": {
        "required_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "covered_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "linked_evidence_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "total_evidence_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "linkage_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "missing_ids": {
          "$ref": "#/$defs/string_array"
        },
        "invalid_source_refs": {
          "$ref": "#/$defs/string_array"
        },
        "passed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "assumption_exposure_metric": {
      "type": "object",
      "required": [
        "required_count",
        "covered_count",
        "assumption_count",
        "stale_assumption_count",
        "stale_evidence_count",
        "verification_gap_count",
        "due_revisit_count",
        "passed"
      ],
      "properties": {
        "required_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "covered_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "assumption_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "stale_assumption_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "stale_evidence_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "verification_gap_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "due_revisit_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "missing_ids": {
          "$ref": "#/$defs/string_array"
        },
        "passed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "action_executability_metric": {
      "type": "object",
      "required": [
        "readiness",
        "action_count",
        "implementation_ready_count",
        "blocker_count",
        "unresolved_conflict_count",
        "passed"
      ],
      "properties": {
        "readiness": {
          "enum": [
            "ready",
            "conditional",
            "blocked"
          ]
        },
        "action_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "implementation_ready_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "blocker_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "unresolved_conflict_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "passed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "document_validity_metric": {
      "type": "object",
      "required": [
        "required_sections_present",
        "empty_required_sections",
        "missing_source_traceability",
        "passed"
      ],
      "properties": {
        "required_sections_present": {
          "type": "boolean"
        },
        "empty_required_sections": {
          "$ref": "#/$defs/string_array"
        },
        "missing_source_traceability": {
          "$ref": "#/$defs/string_array"
        },
        "passed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "runtime_performance_metric": {
      "type": "object",
      "required": [
        "total_seconds",
        "load_runtime_seconds",
        "event_count",
        "session_count",
        "object_count",
        "decision_count",
        "max_total_seconds",
        "max_load_runtime_seconds",
        "passed"
      ],
      "properties": {
        "total_seconds": {
          "type": "number",
          "minimum": 0
        },
        "load_runtime_seconds": {
          "type": "number",
          "minimum": 0
        },
        "event_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "session_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "object_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "decision_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "max_total_seconds": {
          "$ref": "#/$defs/nullable_number"
        },
        "max_load_runtime_seconds": {
          "$ref": "#/$defs/nullable_number"
        },
        "passed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "failure": {
      "type": "object",
      "required": [
        "metric",
        "message"
      ],
      "properties": {
        "metric": {
          "$ref": "#/$defs/metric_name"
        },
        "message": {
          "$ref": "#/$defs/non_empty_string"
        },
        "path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "expected": true,
        "actual": true
      },
      "additionalProperties": false
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
