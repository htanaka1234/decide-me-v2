{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/close-summary.schema.json",
  "title": "Decide Me Close Summary",
  "type": "object",
  "required": [
    "work_item",
    "readiness",
    "object_ids",
    "link_ids",
    "generated_at"
  ],
  "properties": {
    "work_item": {
      "type": "object",
      "required": [
        "title",
        "statement",
        "objective_object_id"
      ],
      "properties": {
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "statement": {
          "type": [
            "string",
            "null"
          ]
        },
        "objective_object_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "readiness": {
      "type": "string",
      "enum": [
        "ready",
        "conditional",
        "blocked"
      ]
    },
    "object_ids": {
      "type": "object",
      "required": [
        "decisions",
        "accepted_decisions",
        "deferred_decisions",
        "blockers",
        "risks",
        "actions",
        "evidence",
        "verifications",
        "revisit_triggers"
      ],
      "properties": {
        "decisions": {
          "$ref": "#/$defs/idList"
        },
        "accepted_decisions": {
          "$ref": "#/$defs/idList"
        },
        "deferred_decisions": {
          "$ref": "#/$defs/idList"
        },
        "blockers": {
          "$ref": "#/$defs/idList"
        },
        "risks": {
          "$ref": "#/$defs/idList"
        },
        "actions": {
          "$ref": "#/$defs/idList"
        },
        "evidence": {
          "$ref": "#/$defs/idList"
        },
        "verifications": {
          "$ref": "#/$defs/idList"
        },
        "revisit_triggers": {
          "$ref": "#/$defs/idList"
        }
      },
      "additionalProperties": false
    },
    "link_ids": {
      "$ref": "#/$defs/idList"
    },
    "generated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "$defs": {
    "idList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
