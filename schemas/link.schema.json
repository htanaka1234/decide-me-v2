{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/link.schema.json",
  "title": "Decide Me Object Link",
  "type": "object",
  "required": [
    "id",
    "source_object_id",
    "relation",
    "target_object_id",
    "rationale",
    "created_at",
    "source_event_ids"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "source_object_id": {
      "type": "string",
      "minLength": 1
    },
    "relation": {
      "type": "string",
      "enum": [
        "depends_on",
        "supports",
        "challenges",
        "recommends",
        "accepts",
        "addresses",
        "verifies",
        "revisits",
        "supersedes",
        "blocked_by"
      ]
    },
    "target_object_id": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_event_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
