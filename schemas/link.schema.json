{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/link.schema.json",
  "title": "Decide Me Object Link",
  "type": "object",
  "required": [
    "id",
    "source_object_id",
    "relation",
    "target_object_id",
    "rationale",
    "created_at",
    "source_event_ids"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "source_object_id": {
      "type": "string",
      "minLength": 1
    },
    "relation": {
      "type": "string",
      "enum": [
        "depends_on",
        "supports",
        "challenges",
        "recommends",
        "accepts",
        "addresses",
        "verifies",
        "revisits",
        "supersedes",
        "blocked_by",
        "constrains",
        "enables",
        "requires",
        "invalidates",
        "mitigates",
        "derived_from"
      ]
    },
    "target_object_id": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_event_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "properties": {
        "source_document_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "source_unit_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "source_unit_hash": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "citation": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "quote": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "interpretation_note": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "effective_from": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "effective_to": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "linked_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
