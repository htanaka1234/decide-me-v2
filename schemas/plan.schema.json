{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/plan.schema.json",
  "title": "Decide Me Plan Output",
  "type": "object",
  "required": [
    "generated_at",
    "source_session_ids",
    "status",
    "conflicts",
    "action_plan"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_session_ids": {
      "$ref": "#/$defs/idList"
    },
    "status": {
      "type": "string",
      "enum": [
        "conflicts",
        "action-plan"
      ]
    },
    "conflicts": {
      "type": "array"
    },
    "action_plan": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": [
            "readiness",
            "goals",
            "workstreams",
            "actions",
            "implementation_ready_actions",
            "blockers",
            "risks",
            "evidence_refs"
          ],
          "properties": {
            "readiness": {
              "type": "string",
              "enum": [
                "ready",
                "conditional",
                "blocked"
              ]
            },
            "goals": {
              "type": "array"
            },
            "workstreams": {
              "type": "array"
            },
            "actions": {
              "type": "array"
            },
            "implementation_ready_actions": {
              "type": "array"
            },
            "blockers": {
              "type": "array"
            },
            "risks": {
              "type": "array"
            },
            "evidence_refs": {
              "type": "array"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "export_path": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "idList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
