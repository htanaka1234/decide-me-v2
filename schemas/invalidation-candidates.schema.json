{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/invalidation-candidates.schema.json",
  "title": "Decide Me Invalidation Candidates",
  "type": "object",
  "required": [
    "root_object_id",
    "change_kind",
    "generated_at",
    "impact_summary",
    "candidates"
  ],
  "properties": {
    "root_object_id": {
      "type": "string",
      "minLength": 1
    },
    "change_kind": {
      "$ref": "#/$defs/change_kind"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "impact_summary": {
      "type": "object",
      "required": [
        "affected_count",
        "highest_severity",
        "affected_layers"
      ],
      "properties": {
        "affected_count": {
          "type": "integer",
          "minimum": 0
        },
        "highest_severity": {
          "enum": [
            "none",
            "low",
            "medium",
            "high"
          ]
        },
        "affected_layers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/decision_stack_layer"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "change_kind": {
      "enum": [
        "changed",
        "invalidated",
        "superseded",
        "challenged",
        "assumption_failed",
        "evidence_retracted"
      ]
    },
    "candidate_kind": {
      "enum": [
        "review",
        "revalidate",
        "revise",
        "invalidate",
        "supersede",
        "add_verification",
        "update_revisit_trigger"
      ]
    },
    "object_type": {
      "enum": [
        "objective",
        "constraint",
        "criterion",
        "option",
        "proposal",
        "decision",
        "assumption",
        "evidence",
        "risk",
        "action",
        "verification",
        "revisit_trigger",
        "artifact"
      ]
    },
    "link_relation": {
      "enum": [
        "depends_on",
        "supports",
        "challenges",
        "recommends",
        "accepts",
        "addresses",
        "verifies",
        "revisits",
        "supersedes",
        "blocked_by",
        "constrains",
        "enables",
        "requires",
        "invalidates",
        "mitigates",
        "derived_from"
      ]
    },
    "decision_stack_layer": {
      "enum": [
        "purpose",
        "principle",
        "constraint",
        "strategy",
        "design",
        "execution",
        "verification",
        "review"
      ]
    },
    "severity": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "impact_kind": {
      "enum": [
        "decision_review_required",
        "action_rework_candidate",
        "verification_review_required",
        "evidence_review_required",
        "risk_review_required",
        "revisit_condition_review",
        "object_review_required"
      ]
    },
    "candidate": {
      "type": "object",
      "required": [
        "candidate_id",
        "target_object_id",
        "target_object_type",
        "target_status",
        "layer",
        "severity",
        "candidate_kind",
        "reason",
        "requires_human_approval",
        "approval_threshold",
        "materialization_status",
        "materialization_reason",
        "proposed_events",
        "source_impact"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "pattern": "^IC-[0-9a-f]{12}$"
        },
        "target_object_id": {
          "type": "string",
          "minLength": 1
        },
        "target_object_type": {
          "$ref": "#/$defs/object_type"
        },
        "target_status": {
          "type": "string",
          "minLength": 1
        },
        "layer": {
          "$ref": "#/$defs/decision_stack_layer"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "candidate_kind": {
          "$ref": "#/$defs/candidate_kind"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "requires_human_approval": {
          "type": "boolean"
        },
        "approval_threshold": {
          "enum": [
            "none",
            "explicit_acceptance"
          ]
        },
        "materialization_status": {
          "enum": [
            "materialized",
            "manual"
          ]
        },
        "materialization_reason": {
          "type": "string",
          "minLength": 1
        },
        "proposed_events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/proposed_event"
          }
        },
        "source_impact": {
          "$ref": "#/$defs/source_impact"
        }
      },
      "additionalProperties": false
    },
    "source_impact": {
      "type": "object",
      "required": [
        "via_link_id",
        "via_relation",
        "distance",
        "impact_kind"
      ],
      "properties": {
        "via_link_id": {
          "type": "string",
          "minLength": 1
        },
        "via_relation": {
          "$ref": "#/$defs/link_relation"
        },
        "distance": {
          "type": "integer",
          "minimum": 1
        },
        "impact_kind": {
          "$ref": "#/$defs/impact_kind"
        }
      },
      "additionalProperties": false
    },
    "proposed_event": {
      "oneOf": [
        {
          "$ref": "#/$defs/object_status_changed_draft"
        },
        {
          "$ref": "#/$defs/object_updated_draft"
        },
        {
          "$ref": "#/$defs/object_recorded_draft"
        },
        {
          "$ref": "#/$defs/object_linked_draft"
        }
      ]
    },
    "object_status_changed_draft": {
      "type": "object",
      "required": [
        "event_type",
        "payload"
      ],
      "properties": {
        "event_type": {
          "const": "object_status_changed"
        },
        "payload": {
          "type": "object",
          "required": [
            "object_id",
            "from_status",
            "to_status",
            "reason"
          ],
          "properties": {
            "object_id": {
              "type": "string",
              "minLength": 1
            },
            "from_status": {
              "type": "string",
              "minLength": 1
            },
            "to_status": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "object_updated_draft": {
      "type": "object",
      "required": [
        "event_type",
        "payload"
      ],
      "properties": {
        "event_type": {
          "const": "object_updated"
        },
        "payload": {
          "type": "object",
          "required": [
            "object_id",
            "patch"
          ],
          "properties": {
            "object_id": {
              "type": "string",
              "minLength": 1
            },
            "patch": {
              "type": "object",
              "required": [
                "metadata"
              ],
              "properties": {
                "metadata": {
                  "type": "object",
                  "required": [
                    "invalidated_by"
                  ],
                  "properties": {
                    "invalidated_by": {
                      "type": "object",
                      "required": [
                        "decision_id",
                        "reason"
                      ],
                      "properties": {
                        "decision_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "reason": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "object_recorded_draft": {
      "type": "object",
      "required": [
        "event_type",
        "payload"
      ],
      "properties": {
        "event_type": {
          "const": "object_recorded"
        },
        "payload": {
          "type": "object",
          "required": [
            "object"
          ],
          "properties": {
            "object": {
              "type": "object",
              "required": [
                "id",
                "type",
                "title",
                "body",
                "status",
                "metadata"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "type": {
                  "const": "verification"
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "body": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "minLength": 1
                },
                "metadata": {
                  "$ref": "#/$defs/verification_metadata"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "object_linked_draft": {
      "type": "object",
      "required": [
        "event_type",
        "payload"
      ],
      "properties": {
        "event_type": {
          "const": "object_linked"
        },
        "payload": {
          "type": "object",
          "required": [
            "link"
          ],
          "properties": {
            "link": {
              "type": "object",
              "required": [
                "id",
                "source_object_id",
                "relation",
                "target_object_id",
                "rationale"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "source_object_id": {
                  "type": "string",
                  "minLength": 1
                },
                "relation": {
                  "$ref": "#/$defs/link_relation"
                },
                "target_object_id": {
                  "type": "string",
                  "minLength": 1
                },
                "rationale": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "verification_metadata": {
      "type": "object",
      "required": [
        "method",
        "expected_result",
        "verified_at",
        "result"
      ],
      "properties": {
        "method": {
          "enum": [
            "inspection",
            "test",
            "review",
            "analysis",
            "monitoring"
          ]
        },
        "expected_result": {
          "type": "string",
          "minLength": 1
        },
        "verified_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "result": {
          "enum": [
            "pass",
            "fail",
            "inconclusive",
            "pending"
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
