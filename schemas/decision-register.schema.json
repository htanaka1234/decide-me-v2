{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/decision-register.schema.json",
  "title": "Decide Me Decision Register Export",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "project_head",
    "decisions"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "project_head": {
      "type": [
        "string",
        "null"
      ]
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "domain",
          "kind",
          "priority",
          "frontier",
          "session_id",
          "accepted_via",
          "summary",
          "superseded_by",
          "depends_on",
          "evidence",
          "invalidated_by"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "accepted",
              "resolved-by-evidence",
              "deferred",
              "invalidated"
            ]
          },
          "domain": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "frontier": {
            "type": "string"
          },
          "session_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "accepted_via": {
            "type": [
              "string",
              "null"
            ]
          },
          "summary": {
            "type": [
              "string",
              "null"
            ]
          },
          "superseded_by": {
            "type": [
              "string",
              "null"
            ]
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "invalidated_by": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "decision_id",
              "reason",
              "invalidated_at"
            ],
            "properties": {
              "decision_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "reason": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "invalidated_at": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
