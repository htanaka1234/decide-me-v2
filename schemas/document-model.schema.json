{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/document-model.schema.json",
  "title": "Decide Me Document Model",
  "type": "object",
  "required": [
    "schema_version",
    "document_id",
    "document_type",
    "audience",
    "generated_at",
    "project_head",
    "source",
    "title",
    "sections",
    "warnings",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "document_type": {
      "enum": [
        "decision-brief",
        "action-plan",
        "risk-register",
        "review-memo",
        "research-plan",
        "comparison-table"
      ]
    },
    "audience": {
      "enum": [
        "human"
      ]
    },
    "generated_at": {
      "$ref": "#/$defs/nullable_date_time"
    },
    "project_head": {
      "$ref": "#/$defs/nullable_string"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/section"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "domain_pack_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "domain_pack_version": {
          "type": "string",
          "minLength": 1
        },
        "domain_pack_digest": {
          "type": "string",
          "pattern": "^DP-[0-9a-f]{12}$"
        },
        "document_profile_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      },
      "dependentRequired": {
        "domain_pack_id": [
          "domain_pack_version",
          "domain_pack_digest",
          "document_profile_id"
        ],
        "domain_pack_version": [
          "domain_pack_id",
          "domain_pack_digest",
          "document_profile_id"
        ],
        "domain_pack_digest": [
          "domain_pack_id",
          "domain_pack_version",
          "document_profile_id"
        ],
        "document_profile_id": [
          "domain_pack_id",
          "domain_pack_version",
          "domain_pack_digest"
        ]
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nullable_string": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "nullable_date_time": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "id_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "source": {
      "type": "object",
      "required": [
        "session_ids",
        "object_ids",
        "link_ids",
        "diagnostic_types"
      ],
      "properties": {
        "session_ids": {
          "$ref": "#/$defs/id_list"
        },
        "object_ids": {
          "$ref": "#/$defs/id_list"
        },
        "link_ids": {
          "$ref": "#/$defs/id_list"
        },
        "diagnostic_types": {
          "$ref": "#/$defs/id_list"
        }
      },
      "additionalProperties": false
    },
    "section": {
      "type": "object",
      "required": [
        "id",
        "title",
        "order",
        "blocks",
        "source_object_ids",
        "source_link_ids"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer"
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/block"
          }
        },
        "source_object_ids": {
          "$ref": "#/$defs/id_list"
        },
        "source_link_ids": {
          "$ref": "#/$defs/id_list"
        }
      },
      "additionalProperties": false
    },
    "block": {
      "oneOf": [
        {
          "$ref": "#/$defs/text_block"
        },
        {
          "$ref": "#/$defs/list_block"
        },
        {
          "$ref": "#/$defs/table_block"
        },
        {
          "$ref": "#/$defs/callout_block"
        },
        {
          "$ref": "#/$defs/object_refs_block"
        }
      ]
    },
    "text_block": {
      "type": "object",
      "required": [
        "type",
        "text"
      ],
      "properties": {
        "type": {
          "const": "text"
        },
        "text": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "list_block": {
      "type": "object",
      "required": [
        "type",
        "items"
      ],
      "properties": {
        "type": {
          "const": "list"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cell"
          }
        }
      },
      "additionalProperties": false
    },
    "table_block": {
      "type": "object",
      "required": [
        "type",
        "columns",
        "rows"
      ],
      "properties": {
        "type": {
          "const": "table"
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/cell"
            }
          }
        }
      },
      "additionalProperties": false
    },
    "callout_block": {
      "type": "object",
      "required": [
        "type",
        "severity",
        "text"
      ],
      "properties": {
        "type": {
          "const": "callout"
        },
        "severity": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "object_refs_block": {
      "type": "object",
      "required": [
        "type",
        "object_ids"
      ],
      "properties": {
        "type": {
          "const": "object_refs"
        },
        "object_ids": {
          "$ref": "#/$defs/id_list"
        }
      },
      "additionalProperties": false
    },
    "cell": {
      "type": [
        "string",
        "number",
        "integer",
        "boolean",
        "object",
        "array",
        "null"
      ]
    }
  }
}
