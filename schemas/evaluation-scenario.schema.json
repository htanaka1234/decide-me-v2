{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/evaluation-scenario.schema.json",
  "title": "Decide Me Evaluation Scenario",
  "type": "object",
  "required": [
    "schema_version",
    "scenario_id",
    "label",
    "domain_pack",
    "project",
    "sessions",
    "evaluation"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 2
    },
    "scenario_id": {
      "$ref": "#/$defs/identifier"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "domain_pack": {
      "$ref": "#/$defs/identifier"
    },
    "project": {
      "$ref": "#/$defs/project"
    },
    "sessions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/session"
      }
    },
    "evaluation": {
      "$ref": "#/$defs/evaluation"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "session_id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "relative_jsonl_path": {
      "type": "string",
      "pattern": "^(?!/)(?!.*//)(?!.*(?:^|/)\\.\\.(?:/|$))(?![A-Za-z]:/)[A-Za-z0-9._/-]+\\.jsonl$"
    },
    "project": {
      "type": "object",
      "required": [
        "name",
        "objective",
        "current_milestone"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "objective": {
          "$ref": "#/$defs/non_empty_string"
        },
        "current_milestone": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "session": {
      "type": "object",
      "required": [
        "session_id",
        "context",
        "seed_events",
        "close"
      ],
      "properties": {
        "session_id": {
          "$ref": "#/$defs/session_id"
        },
        "context": {
          "$ref": "#/$defs/non_empty_string"
        },
        "seed_events": {
          "$ref": "#/$defs/relative_jsonl_path"
        },
        "close": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "evaluation": {
      "type": "object",
      "required": [
        "now"
      ],
      "properties": {
        "now": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  }
}
