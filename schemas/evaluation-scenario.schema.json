{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/evaluation-scenario.schema.json",
  "title": "Decide Me Evaluation Scenario",
  "type": "object",
  "required": [
    "schema_version",
    "scenario_id",
    "label",
    "domain_pack",
    "project",
    "sessions",
    "evaluation"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "scenario_id": {
      "$ref": "#/$defs/identifier"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "domain_pack": {
      "$ref": "#/$defs/identifier"
    },
    "project": {
      "$ref": "#/$defs/project"
    },
    "sessions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/session"
      }
    },
    "evaluation": {
      "$ref": "#/$defs/evaluation"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "session_id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "identifier_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/identifier"
      },
      "uniqueItems": true
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "session_id_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/session_id"
      },
      "uniqueItems": true
    },
    "relative_jsonl_path": {
      "type": "string",
      "pattern": "^(?!/)(?!.*//)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+\\.jsonl$"
    },
    "document_type": {
      "enum": [
        "decision-brief",
        "action-plan",
        "risk-register",
        "review-memo",
        "research-plan",
        "comparison-table"
      ]
    },
    "document_format": {
      "enum": [
        "markdown",
        "json",
        "csv"
      ]
    },
    "decision_status": {
      "enum": [
        "unresolved",
        "proposed",
        "blocked",
        "accepted",
        "deferred",
        "resolved-by-evidence",
        "invalidated"
      ]
    },
    "status_count_mode": {
      "enum": [
        "exact",
        "min"
      ]
    },
    "plan_readiness": {
      "enum": [
        "ready",
        "conditional",
        "blocked"
      ]
    },
    "risk_tier": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "approval_threshold": {
      "enum": [
        "none",
        "explicit_acceptance",
        "human_review",
        "external_review"
      ]
    },
    "approval_threshold_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/approval_threshold"
      },
      "uniqueItems": true
    },
    "risk_tier_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk_tier"
      },
      "uniqueItems": true
    },
    "project": {
      "type": "object",
      "required": [
        "name",
        "objective",
        "current_milestone"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "objective": {
          "$ref": "#/$defs/non_empty_string"
        },
        "current_milestone": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "session": {
      "type": "object",
      "required": [
        "session_id",
        "context",
        "seed_events",
        "close"
      ],
      "properties": {
        "session_id": {
          "$ref": "#/$defs/session_id"
        },
        "context": {
          "$ref": "#/$defs/non_empty_string"
        },
        "seed_events": {
          "$ref": "#/$defs/relative_jsonl_path"
        },
        "close": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "evaluation": {
      "type": "object",
      "required": [
        "now",
        "expected_decision_coverage",
        "expected_questions",
        "expected_evidence_coverage",
        "expected_risks",
        "expected_conflicts",
        "expected_documents"
      ],
      "properties": {
        "now": {
          "type": "string",
          "format": "date-time"
        },
        "expected_decision_coverage": {
          "$ref": "#/$defs/expected_decision_coverage"
        },
        "expected_questions": {
          "$ref": "#/$defs/expected_questions"
        },
        "expected_evidence_coverage": {
          "$ref": "#/$defs/expected_evidence_coverage"
        },
        "expected_risks": {
          "$ref": "#/$defs/expected_risks"
        },
        "expected_conflicts": {
          "$ref": "#/$defs/expected_conflicts"
        },
        "expected_safety_gates": {
          "$ref": "#/$defs/expected_safety_gates"
        },
        "expected_plan_executability": {
          "$ref": "#/$defs/expected_plan_executability"
        },
        "expected_revisit_quality": {
          "$ref": "#/$defs/expected_revisit_quality"
        },
        "expected_documents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/expected_document"
          }
        }
      },
      "additionalProperties": false
    },
    "expected_decision_coverage": {
      "type": "object",
      "required": [
        "required_domain_decision_types",
        "required_status_counts"
      ],
      "properties": {
        "required_domain_decision_types": {
          "$ref": "#/$defs/identifier_array"
        },
        "required_status_counts": {
          "$ref": "#/$defs/expected_status_counts"
        }
      },
      "additionalProperties": false
    },
    "expected_status_counts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/expected_status_count"
      }
    },
    "expected_status_count": {
      "type": "object",
      "required": [
        "status",
        "mode",
        "count"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/decision_status"
        },
        "mode": {
          "$ref": "#/$defs/status_count_mode"
        },
        "count": {
          "$ref": "#/$defs/non_negative_integer"
        }
      },
      "additionalProperties": false
    },
    "expected_questions": {
      "type": "object",
      "required": [
        "max_questions",
        "forbidden_repeated_decision_types"
      ],
      "properties": {
        "max_questions": {
          "type": "integer",
          "minimum": 0
        },
        "forbidden_repeated_decision_types": {
          "$ref": "#/$defs/identifier_array"
        },
        "probe_session_ids": {
          "$ref": "#/$defs/session_id_array"
        },
        "advance_steps": {
          "$ref": "#/$defs/non_negative_integer"
        }
      },
      "additionalProperties": false
    },
    "expected_evidence_coverage": {
      "type": "object",
      "required": [
        "min_supporting_evidence",
        "required_evidence_requirement_ids"
      ],
      "properties": {
        "min_supporting_evidence": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "required_evidence_requirement_ids": {
          "$ref": "#/$defs/identifier_array"
        }
      },
      "additionalProperties": false
    },
    "expected_risks": {
      "type": "object",
      "required": [
        "required_domain_risk_types",
        "min_high_or_critical_risks"
      ],
      "properties": {
        "required_domain_risk_types": {
          "$ref": "#/$defs/identifier_array"
        },
        "required_risk_tiers": {
          "$ref": "#/$defs/risk_tier_array"
        },
        "min_high_or_critical_risks": {
          "$ref": "#/$defs/non_negative_integer"
        }
      },
      "additionalProperties": false
    },
    "expected_safety_gates": {
      "type": "object",
      "required": [
        "required_rule_ids",
        "required_approval_thresholds",
        "min_approval_required_count",
        "required_insufficient_evidence_ids"
      ],
      "properties": {
        "required_rule_ids": {
          "$ref": "#/$defs/identifier_array"
        },
        "required_approval_thresholds": {
          "$ref": "#/$defs/approval_threshold_array"
        },
        "min_approval_required_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "required_insufficient_evidence_ids": {
          "$ref": "#/$defs/identifier_array"
        }
      },
      "additionalProperties": false
    },
    "expected_plan_executability": {
      "type": "object",
      "required": [
        "readiness",
        "min_implementation_ready_count"
      ],
      "properties": {
        "readiness": {
          "$ref": "#/$defs/plan_readiness"
        },
        "min_implementation_ready_count": {
          "$ref": "#/$defs/non_negative_integer"
        }
      },
      "additionalProperties": false
    },
    "expected_revisit_quality": {
      "type": "object",
      "required": [
        "mode",
        "count"
      ],
      "properties": {
        "mode": {
          "$ref": "#/$defs/status_count_mode"
        },
        "count": {
          "$ref": "#/$defs/non_negative_integer"
        }
      },
      "additionalProperties": false
    },
    "expected_conflicts": {
      "type": "object",
      "required": [
        "count"
      ],
      "properties": {
        "count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "required_conflict_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "required_conflict_types": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "expected_document": {
      "type": "object",
      "required": [
        "type",
        "format",
        "required_sections"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/document_type"
        },
        "format": {
          "$ref": "#/$defs/document_format"
        },
        "required_sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "require_source_traceability": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}
