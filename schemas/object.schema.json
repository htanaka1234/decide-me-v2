{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/object.schema.json",
  "title": "Decide Me Domain Object",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "body",
    "status",
    "created_at",
    "updated_at",
    "source_event_ids",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "objective",
        "constraint",
        "criterion",
        "option",
        "proposal",
        "decision",
        "assumption",
        "evidence",
        "risk",
        "action",
        "verification",
        "revisit_trigger",
        "artifact"
      ]
    },
    "title": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "body": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "source_event_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "evidence"
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "$ref": "#/$defs/evidence_metadata"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "assumption"
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "$ref": "#/$defs/assumption_metadata"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "risk"
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "$ref": "#/$defs/risk_metadata"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "action"
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "$ref": "#/$defs/action_metadata"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "verification"
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "$ref": "#/$defs/verification_metadata"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "revisit_trigger"
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "$ref": "#/$defs/revisit_trigger_metadata"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "artifact"
          },
          "metadata": {
            "properties": {
              "artifact_type": {
                "const": "safety_gate_approval"
              }
            },
            "required": [
              "artifact_type"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "$ref": "#/$defs/safety_approval_metadata"
          }
        }
      }
    }
  ],
  "$defs": {
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "nullable_date_time": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "action_type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "evidence_metadata": {
      "type": "object",
      "required": [
        "source",
        "source_ref",
        "summary",
        "confidence",
        "freshness",
        "observed_at",
        "valid_until"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "codebase",
            "docs",
            "tests",
            "external",
            "existing-decisions",
            "close-summaries",
            "source-store"
          ]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "freshness": {
          "type": "string",
          "enum": [
            "current",
            "stale",
            "unknown"
          ]
        },
        "observed_at": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "valid_until": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "source_document_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "source_unit_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "source_unit_hash": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "citation": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "quote": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "interpretation_note": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "effective_from": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "effective_to": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        }
      },
      "additionalProperties": true
    },
    "assumption_metadata": {
      "type": "object",
      "required": [
        "statement",
        "confidence",
        "validation",
        "invalidates_if_false",
        "expires_at",
        "owner"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "validation": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "invalidates_if_false": {
          "$ref": "#/$defs/string_array"
        },
        "expires_at": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "owner": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "risk_metadata": {
      "type": "object",
      "required": [
        "statement",
        "severity",
        "likelihood",
        "risk_tier",
        "reversibility",
        "mitigation_object_ids",
        "approval_threshold"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "likelihood": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "risk_tier": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "reversibility": {
          "type": "string",
          "enum": [
            "reversible",
            "partially_reversible",
            "irreversible"
          ]
        },
        "mitigation_object_ids": {
          "$ref": "#/$defs/string_array"
        },
        "approval_threshold": {
          "type": "string",
          "enum": [
            "none",
            "explicit_acceptance",
            "human_review",
            "external_review"
          ]
        }
      },
      "additionalProperties": true
    },
    "action_metadata": {
      "type": "object",
      "properties": {
        "action_type": {
          "$ref": "#/$defs/action_type"
        },
        "implementation_ready": {
          "type": "boolean"
        },
        "required_inputs": {
          "$ref": "#/$defs/string_array"
        },
        "outputs": {
          "$ref": "#/$defs/string_array"
        },
        "verification_refs": {
          "$ref": "#/$defs/string_array"
        },
        "source_decision_refs": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": true
    },
    "verification_metadata": {
      "type": "object",
      "required": [
        "method",
        "expected_result",
        "verified_at",
        "result"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "inspection",
            "test",
            "review",
            "analysis",
            "monitoring"
          ]
        },
        "expected_result": {
          "type": "string",
          "minLength": 1
        },
        "verified_at": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "result": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "inconclusive",
            "pending"
          ]
        }
      },
      "additionalProperties": true
    },
    "revisit_trigger_metadata": {
      "type": "object",
      "required": [
        "trigger_type",
        "condition",
        "due_at",
        "target_object_ids"
      ],
      "properties": {
        "trigger_type": {
          "type": "string",
          "enum": [
            "time",
            "evidence",
            "outcome",
            "dependency"
          ]
        },
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "due_at": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "target_object_ids": {
          "allOf": [
            {
              "$ref": "#/$defs/string_array"
            },
            {
              "minItems": 1
            }
          ]
        }
      },
      "additionalProperties": true
    },
    "safety_approval_metadata": {
      "type": "object",
      "required": [
        "artifact_type",
        "target_object_id",
        "gate_digest",
        "approval_threshold",
        "approval_level",
        "approved_by",
        "approved_at",
        "reason",
        "expires_at"
      ],
      "properties": {
        "artifact_type": {
          "const": "safety_gate_approval"
        },
        "target_object_id": {
          "type": "string",
          "minLength": 1
        },
        "gate_digest": {
          "type": "string",
          "pattern": "^SG-[0-9a-f]{12}$"
        },
        "approval_threshold": {
          "type": "string",
          "enum": [
            "none",
            "explicit_acceptance",
            "human_review",
            "external_review"
          ]
        },
        "approval_level": {
          "type": "string",
          "enum": [
            "explicit_acceptance",
            "human_review",
            "external_review"
          ]
        },
        "approved_by": {
          "type": "string",
          "minLength": 1
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "expires_at": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "layer": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
