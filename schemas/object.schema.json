{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/object.schema.json",
  "title": "Decide Me Domain Object",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "body",
    "status",
    "created_at",
    "updated_at",
    "source_event_ids",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "objective",
        "constraint",
        "criterion",
        "option",
        "proposal",
        "decision",
        "assumption",
        "evidence",
        "risk",
        "action",
        "verification",
        "revisit_trigger",
        "artifact"
      ]
    },
    "title": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "body": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "source_event_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
