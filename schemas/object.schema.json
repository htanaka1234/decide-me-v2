{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decide-me/object.schema.json",
  "title": "Decide Me Domain Object",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "body",
    "status",
    "created_at",
    "updated_at",
    "source_event_ids",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "objective",
        "constraint",
        "criterion",
        "option",
        "proposal",
        "decision",
        "assumption",
        "evidence",
        "risk",
        "action",
        "verification",
        "revisit_trigger",
        "artifact"
      ]
    },
    "title": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "body": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "source_event_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "evidence"
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "$ref": "#/$defs/evidence_metadata"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "assumption"
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "$ref": "#/$defs/assumption_metadata"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "risk"
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "$ref": "#/$defs/risk_metadata"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "verification"
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "$ref": "#/$defs/verification_metadata"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "revisit_trigger"
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "$ref": "#/$defs/revisit_trigger_metadata"
          }
        }
      }
    }
  ],
  "$defs": {
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "nullable_date_time": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "evidence_metadata": {
      "type": "object",
      "required": [
        "source",
        "source_ref",
        "summary",
        "confidence",
        "freshness",
        "observed_at",
        "valid_until"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "codebase",
            "docs",
            "tests",
            "external",
            "existing-decisions",
            "close-summaries"
          ]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "freshness": {
          "type": "string",
          "enum": [
            "current",
            "stale",
            "unknown"
          ]
        },
        "observed_at": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "valid_until": {
          "$ref": "#/$defs/nullable_date_time"
        }
      },
      "additionalProperties": true
    },
    "assumption_metadata": {
      "type": "object",
      "required": [
        "statement",
        "confidence",
        "validation",
        "invalidates_if_false",
        "expires_at",
        "owner"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "validation": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "invalidates_if_false": {
          "$ref": "#/$defs/string_array"
        },
        "expires_at": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "owner": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "risk_metadata": {
      "type": "object",
      "required": [
        "statement",
        "severity",
        "likelihood",
        "risk_tier",
        "reversibility",
        "mitigation_object_ids",
        "approval_threshold"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "likelihood": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "risk_tier": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "reversibility": {
          "type": "string",
          "enum": [
            "reversible",
            "partially_reversible",
            "irreversible"
          ]
        },
        "mitigation_object_ids": {
          "$ref": "#/$defs/string_array"
        },
        "approval_threshold": {
          "type": "string",
          "enum": [
            "none",
            "explicit_acceptance",
            "human_review",
            "external_review"
          ]
        }
      },
      "additionalProperties": true
    },
    "verification_metadata": {
      "type": "object",
      "required": [
        "method",
        "expected_result",
        "verified_at",
        "result"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "inspection",
            "test",
            "review",
            "analysis",
            "monitoring"
          ]
        },
        "expected_result": {
          "type": "string",
          "minLength": 1
        },
        "verified_at": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "result": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "inconclusive",
            "pending"
          ]
        }
      },
      "additionalProperties": true
    },
    "revisit_trigger_metadata": {
      "type": "object",
      "required": [
        "trigger_type",
        "condition",
        "due_at",
        "target_object_ids"
      ],
      "properties": {
        "trigger_type": {
          "type": "string",
          "enum": [
            "time",
            "evidence",
            "outcome",
            "dependency"
          ]
        },
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "due_at": {
          "$ref": "#/$defs/nullable_date_time"
        },
        "target_object_ids": {
          "allOf": [
            {
              "$ref": "#/$defs/string_array"
            },
            {
              "minItems": 1
            }
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
